<h1>Your Profile</h1>

<% if notice %>
  <div class="notice"><%= notice %></div>
<% end %>

<div class="info-card">
  <h2>Profile Information</h2>

  <div class="profile-field">
    <h3>Email</h3>
    <p><%= current_user.email %></p>
  </div>

  <div class="profile-field">
    <h3>Name</h3>
    <p><%= current_user.name.presence || "Not set" %></p>
  </div>

  <div class="profile-field">
    <h3>Date of Birth</h3>
    <p><%= current_user.date_of_birth.presence || "Not set" %></p>
  </div>

  <div class="card-actions">
    <%= link_to "Edit Profile", edit_profile_path, class: "btn" %>
  </div>
</div>

<%= render partial: "card_informations/card_informations", locals: { card_informations: current_user.card_informations.active } %>