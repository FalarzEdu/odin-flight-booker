<div class="booking-card">
  <div class="booking-header">
    <h2><%= booking.flight.route.departure_airport.code %> → <%= booking.flight.route.arrival_airport.code %></h2>
    <span class="status-badge <%= booking.status %>"><%= booking.status.titleize %></span>
  </div>

  <div class="booking-details">
    <div class="detail-row">
      <span class="detail-label">Departure:</span>
      <span class="detail-value"><%= booking.flight.departure_datetime.strftime("%b %d, %Y at %I:%M %p") %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">From:</span>
      <span class="detail-value"><%= booking.flight.route.departure_airport.name %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">To:</span>
      <span class="detail-value"><%= booking.flight.route.arrival_airport.name %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Duration:</span>
      <span class="detail-value"><%= booking.flight.flight_duration %> minutes</span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Passengers:</span>
      <span class="detail-value"><%= booking.passengers.count %></span>
    </div>
  </div>

  <div class="booking-pricing">
    <div class="pricing-row">
      <span class="pricing-label">Flight Price:</span>
      <span class="pricing-value"><%= number_to_currency(booking.flight.price) %></span>
    </div>
    <div class="pricing-row">
      <span class="pricing-label">Total Paid:</span>
      <span class="pricing-value"><%= number_to_currency(booking.total_paid) %></span>
    </div>
    <% if booking.pending_payment? %>
      <div class="pricing-row remaining">
        <span class="pricing-label">Remaining:</span>
        <span class="pricing-value"><%= number_to_currency(booking.flight.price - booking.total_paid) %></span>
      </div>
    <% end %>
  </div>

  <div class="booking-actions">
    <%= link_to "View Details", booking_path(booking), class: "btn-secondary" %>
    <% if booking.pending_payment? %>
      <%= link_to "Pay Now", new_booking_payment_path(booking), class: "btn" %>
    <% end %>
  </div>
</div>